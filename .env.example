# ============================================================
# Recruitment Assessment API — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.

# ------------------------------------------------------------
# OpenRouter API Key (required for CV summarization)
# Get your free key at: https://openrouter.ai/
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------------------------------------------
# OpenRouter Model (optional)
# Default: meta-llama/llama-3.3-70b-instruct:free (confirmed free July 2026)
# Check current free models: https://openrouter.ai/collections/free-models
# Other free options: qwen/qwen3-coder:free, openai/gpt-oss-120b:free
# ------------------------------------------------------------
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ------------------------------------------------------------
# Tavily API Key (required for news search)
# Get your free key at: https://tavily.com/
# ------------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here
